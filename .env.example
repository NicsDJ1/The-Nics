PORT=3000
HOST=0.0.0.0

# Produção: conexão PostgreSQL do Neon.
DATABASE_URL=postgresql://usuario:senha@host/neondb?sslmode=require
DATABASE_SSL=true

# Primeiro gestor. A senha é usada somente se ainda não existir gestor no banco.
ADMIN_USERNAME=nicolas
ADMIN_NAME=Nicolas
ADMIN_PASSWORD=troque-por-uma-senha-forte

# Desenvolvimento sem DATABASE_URL usa SQLite local.
# DB_PATH=./data/territorio.sqlite
